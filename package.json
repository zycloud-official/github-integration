{
  "name": "github-integration",
  "version": "1.0.0",
  "description": "GitHub App webhook server at github-integration.zycloud.space — auto-deploys member repos to CapRover",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "dev:db:generate": "prisma generate --schema=prisma/schema.dev.prisma",
    "dev:db:push": "prisma db push --schema=prisma/schema.dev.prisma",
    "dev:db:studio": "prisma studio --schema=prisma/schema.dev.prisma",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:studio": "prisma studio"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@octokit/app": "^15.1.0",
    "@prisma/client": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.4.0",
    "express": "^5.0.0",
    "prisma": "^6.0.0",
    "tar": "^7.4.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.0.0",
    "supertest": "^7.0.0",
    "vitest": "^3.0.0"
  }
}
