# Database
# Local dev (SQLite):
#   DATABASE_PROVIDER=sqlite
#   DATABASE_URL="file:./data/zycloud.db"
# Production (PostgreSQL):
#   DATABASE_PROVIDER=postgres
#   DATABASE_URL="postgresql://user:password@host:5432/dbname"
DATABASE_PROVIDER=sqlite
DATABASE_URL="file:./data/zycloud.db"
